# Database configuration
# Recommended: Default to Neon Postgres
DATABASE_URI="postgresql://user:password@host/dbname?sslmode=require"

# Deterministic table prefix (e.g., zerwane_)
DATABASE_TABLE_PREFIX="zerwane_"

# Deployment Configuration
NODE_DEPLOY_HOST=
NODE_DEPLOY_USER=
NODE_DEPLOY_PATH=
NODE_DEPLOY_PORT=
NODE_DEPLOY_INSTALL_CMD=
NODE_DEPLOY_BUILD_CMD=
NODE_DEPLOY_RESTART_CMD=
